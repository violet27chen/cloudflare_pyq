---
import BaseLayout from '@layouts/BaseLayout.astro';
import { Feed } from '@components/Feed';
import '../styles/global.css';
---

<BaseLayout>
  <Fragment slot="head">
    {/* 提前发起 profile 请求并预热封面图缓存，与页面 JS/CSS 并行下载 */}
    <script is:inline>
      (function () {
        try {
          window.__coverPromise = fetch('/api/profile', { headers: { Accept: 'application/json' } })
            .then(function (r) { return r && r.ok ? r.json() : null; })
            .then(function (data) {
              if (!data || !data.cover_image_url) return null;
              var url = data.cover_image_url;
              window.__coverUrl = url;
              if (!/\.(mp4|webm|mov)(\?.*)?$/i.test(url)) {
                var img = new Image();
                img.decoding = 'async';
                img.src = url;
              }
              return url;
            })
            .catch(function () { return null; });
        } catch (e) { window.__coverPromise = Promise.resolve(null); }
      })();
    </script>
  </Fragment>

  <!-- Sticky glass header -->
  <header class="m-glass sticky top-0 z-40">
    <div class="mx-auto flex h-14 max-w-[1200px] items-center justify-between px-4">
      <span class="text-sm font-semibold" style={{ color: 'var(--fg)' }}>moments</span>
      <span class="m-meta">moments</span>
    </div>
  </header>

  <!-- Feed — 全宽双列布局 -->
  <main class="mx-auto max-w-[1200px] px-4 pb-16 pt-6">
    <Feed client:load />
  </main>

  {/* hydration 前将封面图填入 #cover-img，消除等待 React 渲染导致的空白窗口 */}
  <script is:inline>
    (function () {
      function fill(url) {
        if (!url || /\.(mp4|webm|mov)(\?.*)?$/i.test(url)) return;
        var el = document.getElementById('cover-img');
        if (el && !el.getAttribute('src')) el.src = url;
      }
      var p = window.__coverPromise;
      if (p && typeof p.then === 'function') {
        p.then(fill);
      } else {
        fetch('/api/profile', { headers: { Accept: 'application/json' } })
          .then(function (r) { return r && r.ok ? r.json() : null; })
          .then(function (d) { fill(d && d.cover_image_url); })
          .catch(function () {});
      }
    })();
  </script>
</BaseLayout>
